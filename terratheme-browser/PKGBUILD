# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=terratheme-browser
pkgver=0.1.0
pkgrel=1
pkgdesc="Terra DE browser extension native messaging host — bridges palette.json to the browser extension"
arch=('any')
url="https://github.com/terra-de/terratheme-browser"
license=('MIT')
depends=('python')
source=("https://github.com/terra-de/terratheme-browser/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('4cfefd2db8a259ebd51cdac604cc1316e17414ff0d05270645bf3084e620174a')

package() {
  cd "$srcdir/terratheme-browser-${pkgver}"

  # Native messaging host script
  install -Dm755 "host/terratheme-browser.py" \
    "$pkgdir/usr/share/terratheme-browser/terratheme-browser.py"

  # Native messaging manifest (system-wide Firefox)
  install -Dm644 "host/terratheme_browser.json" \
    "$pkgdir/usr/lib/mozilla/native-messaging-hosts/terratheme_browser.json"
}
