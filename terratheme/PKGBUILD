# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=terratheme
pkgver=0.4.0
pkgrel=1
pkgdesc="Multi-source-color theme generator for Terra DE"
arch=(any)
url="https://github.com/terra-de/terratheme"
license=('MIT')
depends=(
  'python'
  'python-numpy'
  'python-pillow'
  'python-scikit-learn'
)
makedepends=('python-build' 'python-installer' 'python-wheel' 'python-setuptools')
source=("https://github.com/terra-de/terratheme/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('c733b7c93d943910221d6ab1f821b79b934767a873814f1508cbe991985ba140')

package() {
  cd "$srcdir/terratheme-${pkgver}"
  python -m build --wheel --no-isolation
  python -m installer --destdir="$pkgdir" dist/*.whl
}
