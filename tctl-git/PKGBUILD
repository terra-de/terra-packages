# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=tctl-git
pkgver=0.3.1.r6.ge41f118
pkgrel=1
pkgdesc="Terra DE CLI - multi-purpose command-line tool (git)"
arch=('any')
url="https://github.com/terra-de/tctl"
license=('MIT')
depends=('bash' 'brightnessctl')
makedepends=('git')
provides=('tctl')
conflicts=('tctl')
replaces=('tctl')
source=("git+https://github.com/terra-de/tctl.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/tctl"
  local tag
  tag="$(git describe --tags --abbrev=0 2>/dev/null)" && tag="${tag#v}" || tag="0.0.0"
  printf "%s.r%s.g%s" "$tag" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  cd "$srcdir/tctl"
  install -Dm755 tctl "$pkgdir/usr/bin/tctl"
  install -dm755 "$pkgdir/usr/share/tctl/subcommands"
  install -Dm755 subcommands/brightness "$pkgdir/usr/share/tctl/subcommands/brightness"
  install -Dm755 subcommands/gesture "$pkgdir/usr/share/tctl/subcommands/gesture"
  install -Dm755 subcommands/keys "$pkgdir/usr/share/tctl/subcommands/keys"
  install -Dm755 subcommands/dump "$pkgdir/usr/share/tctl/subcommands/dump"
}
