# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=terrashell
pkgver=0.2.0
pkgrel=1
pkgdesc="Terra DE Quickshell configuration"
arch=('any')
url="https://github.com/terra-de/terrashell"
license=('MIT')
depends=('quickshell' 'ttheme' 'tctl')
optdepends=('terratheme: wallpaper-to-palette integration')
conflicts=('terrashell-git')
source=("https://github.com/terra-de/terrashell/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('c29ac9863a5dbd45560647faebaa38340423112558d52aa8b43534a91bbb2764')

package() {
  cd "$srcdir/terrashell-${pkgver}"

  # Wrapper binary
  install -Dm755 terrashell "$pkgdir/usr/bin/terrashell"

  # Entry point
  install -Dm644 shell.qml "$pkgdir/usr/share/terrashell/shell.qml"
  install -Dm644 filemanager.qml "$pkgdir/usr/share/terrashell/filemanager.qml"

  # QML source tree
  for dir in app config design features services tests utils; do
    [ -d "$dir" ] && cp -a "$dir" "$pkgdir/usr/share/terrashell/"
  done

  # Assets (sounds)
  cp -a assets "$pkgdir/usr/share/terrashell/"

  # Development scripts
  cp -a scripts "$pkgdir/usr/share/terrashell/"
}
