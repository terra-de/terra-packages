# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=terratheme-git
pkgver=0.4.0.r29.g8034ab1
pkgrel=1
pkgdesc="Multi-source-color theme generator for Terra DE (git)"
arch=(any)
url="https://github.com/terra-de/terratheme"
license=('MIT')
depends=(
  'python'
  'python-numpy'
  'python-pillow'
  'python-scikit-learn'
)
makedepends=('git' 'python-build' 'python-installer' 'python-wheel' 'python-setuptools')
provides=('terratheme')
conflicts=('terratheme')
source=("git+https://github.com/terra-de/terratheme.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/terratheme"
  local tag
  tag="$(git describe --tags --abbrev=0 2>/dev/null)" && tag="${tag#v}" || tag="0.0.0"
  printf "%s.r%s.g%s" "$tag" "$(git rev-list --count HEAD)" "$(git rev-parse --short HEAD)"
}

package() {
  cd "$srcdir/terratheme"
  python -m build --wheel --no-isolation
  python -m installer --destdir="$pkgdir" dist/*.whl
}
