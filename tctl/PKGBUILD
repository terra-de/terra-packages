# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=tctl
pkgver=0.1.1
pkgrel=1
pkgdesc="Terra DE CLI - multi-purpose command-line tool"
arch=('any')
url="https://github.com/terra-de/tctl"
license=('MIT')
depends=('bash' 'brightnessctl')
conflicts=('tctl-git')
source=("https://github.com/terra-de/tctl/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('b10ccc8396f576bef4ac016cc11b3e9758f10eec4dbd001143ecf4f61dcd3f08')

package() {
  cd "$srcdir/tctl-${pkgver}"
  install -Dm755 tctl "$pkgdir/usr/bin/tctl"
  install -dm755 "$pkgdir/usr/share/tctl/subcommands"
  install -Dm755 subcommands/brightness "$pkgdir/usr/share/tctl/subcommands/brightness"
}
