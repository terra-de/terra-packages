# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=ttheme-git
pkgver=0.1.r6.g2a80d3e
pkgrel=1
pkgdesc="QML lib for Terra DE theming engine (git)"
arch=(any)
url="https://github.com/terra-de/TTheme"
license=('MIT')
depends=('qt6-declarative')
makedepends=('git')
provides=('ttheme')
conflicts=('ttheme')
replaces=('ttheme')
source=("git+ssh://git@github.com/terra-de/TTheme.git")
sha256sums=('SKIP')

pkgver() {
  cd "$srcdir/TTheme"
  git describe --long --tags 2>/dev/null || echo "0.1.r$(git rev-list --count HEAD).g$(git rev-parse --short HEAD)"
}

package() {
  cd "$srcdir/TTheme"
  install -dm755 "$pkgdir/usr/lib/qt6/qml/TTheme"
  install -Dm644 TTheme/qmldir "$pkgdir/usr/lib/qt6/qml/TTheme/qmldir"
  install -Dm644 TTheme/Palette.qml "$pkgdir/usr/lib/qt6/qml/TTheme/Palette.qml"
  install -Dm644 TTheme/PaletteUtils.js "$pkgdir/usr/lib/qt6/qml/TTheme/PaletteUtils.js"
}
