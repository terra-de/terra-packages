# Maintainer: DevTrev <devtrev00 at gmail dot com>

pkgname=ttheme
pkgver=0.1.0
pkgrel=1
pkgdesc="QML lib for Terra DE theming engine"
arch=(any)
url="https://github.com/terra-de/TTheme"
license=('MIT')
depends=('qt6-declarative')
conflicts=('ttheme-git')
source=("https://github.com/terra-de/TTheme/archive/refs/tags/v${pkgver}.tar.gz")
sha256sums=('d5c28983efdfe79e076bd0b4d7961c02f4fde3021493a945e4e055c49ebba844')

package() {
  cd "$srcdir/TTheme-${pkgver}"
  install -dm755 "$pkgdir/usr/lib/qt6/qml/TTheme"
  install -Dm644 TTheme/qmldir "$pkgdir/usr/lib/qt6/qml/TTheme/qmldir"
  install -Dm644 TTheme/Palette.qml "$pkgdir/usr/lib/qt6/qml/TTheme/Palette.qml"
  install -Dm644 TTheme/PaletteUtils.js "$pkgdir/usr/lib/qt6/qml/TTheme/PaletteUtils.js"
}
